# Analytics — fill these in production
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Checkout mode — "stripe" (recommended — keeps customer) | "shopify" | "amazon" (fallback)
NEXT_PUBLIC_CHECKOUT_MODE=amazon

# Amazon listing URL (used when CHECKOUT_MODE=amazon OR as Stripe fallback)
NEXT_PUBLIC_AMAZON_URL=https://www.amazon.com/dp/B0DHJ74TCC

# Stripe Payment Links — one per variant combination
# Create these in Stripe Dashboard → Payment Links. Accepts card, Apple Pay,
# Google Pay, Link natively. Optional: add PayPal, Klarna, Afterpay.
NEXT_PUBLIC_STRIPE_LINK_SHOWER_SINGLE_CHROME=
NEXT_PUBLIC_STRIPE_LINK_SHOWER_SINGLE_BLACK=
NEXT_PUBLIC_STRIPE_LINK_SHOWER_SUBSCRIBE_CHROME=
NEXT_PUBLIC_STRIPE_LINK_SHOWER_SUBSCRIBE_BLACK=

# Shopify — only used when CHECKOUT_MODE=shopify
NEXT_PUBLIC_SHOPIFY_DOMAIN=feelslikeom.shop
NEXT_PUBLIC_SHOPIFY_VARIANT_SHOWER_SINGLE=
NEXT_PUBLIC_SHOPIFY_VARIANT_SHOWER_SUBSCRIPTION=

# UGC TikTok URLs — real customer videos (auto-hides section if all empty)
NEXT_PUBLIC_UGC_TIKTOK_1=
NEXT_PUBLIC_UGC_TIKTOK_2=
NEXT_PUBLIC_UGC_TIKTOK_3=

# First-order discount code (for water report popup + link param)
NEXT_PUBLIC_FIRST_ORDER_DISCOUNT=WELCOME20

# Water report form endpoint (e.g., Formspree, Klaviyo, custom API)
# When empty, submissions show success state but aren't persisted.
NEXT_PUBLIC_WATER_REPORT_ENDPOINT=
