# Analytics — fill these in production
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Checkout mode — "amazon" (default, until Shopify is live) | "shopify"
NEXT_PUBLIC_CHECKOUT_MODE=amazon

# Amazon listing URL (used when CHECKOUT_MODE=amazon)
NEXT_PUBLIC_AMAZON_URL=https://www.amazon.com/dp/B0DHJ74TCC

# Shopify — base domain (used when CHECKOUT_MODE=shopify)
NEXT_PUBLIC_SHOPIFY_DOMAIN=feelslikeom.shop

# Shopify variant IDs per offer (used when CHECKOUT_MODE=shopify)
# Find these in Shopify admin: Products → [product] → Variants → URL id
NEXT_PUBLIC_SHOPIFY_VARIANT_SHOWER_SINGLE=
NEXT_PUBLIC_SHOPIFY_VARIANT_SHOWER_SUBSCRIPTION=

# First-order discount code (for water report popup + link param)
NEXT_PUBLIC_FIRST_ORDER_DISCOUNT=WELCOME20

# Water report form endpoint (e.g., Formspree, Klaviyo, custom API)
# When empty, submissions show success state but aren't persisted.
NEXT_PUBLIC_WATER_REPORT_ENDPOINT=
