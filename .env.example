# Analytics — fill these in production
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Shopify — base domain of the FLO Shopify store (no trailing slash)
# Used to build checkout permalinks for /cart/add?...
NEXT_PUBLIC_SHOPIFY_DOMAIN=feelslikeom.shop

# Shopify variant IDs per offer
# Find these in Shopify admin: Products → [product] → Variants → URL id
NEXT_PUBLIC_SHOPIFY_VARIANT_SHOWER_SINGLE=
NEXT_PUBLIC_SHOPIFY_VARIANT_SHOWER_SUBSCRIPTION=

# First-order discount code (for exit-intent + link param)
NEXT_PUBLIC_FIRST_ORDER_DISCOUNT=WELCOME20
